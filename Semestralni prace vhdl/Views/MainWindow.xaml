<Window x:Class="Semestralni_prace_vhdl.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Semestralni_prace_vhdl"
        xmlns:vm="clr-namespace:Semestralni_prace_vhdl.ViewModels"
        mc:Ignorable="d"
        Title="Přehled pacientů" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:PřehledPacientuVM />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DataGrid Grid.Row="0"
                  ItemsSource="{Binding Pacienti}"
                  SelectedItem="{Binding VybranyPacient}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />

                <DataGridTextColumn Header="Jméno" Binding="{Binding Jmeno}" Width="*" />

                <DataGridTextColumn Header="Příjmení" Binding="{Binding Prijmeni}" Width="*" />

                <DataGridTextColumn Header="Rodné číslo" Binding="{Binding Cislo_pojistence}" Width="150" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Napsat lékařskou zprávu"
                    Command="{Binding OtevritZpravuCommand}"
                    Padding="10,5"
                    Height="30" />
        </StackPanel>
    </Grid>
</Window>