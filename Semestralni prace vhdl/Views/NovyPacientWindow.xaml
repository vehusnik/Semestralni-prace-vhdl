<Window x:Class="Semestralni_prace_vhdl.Views.NovyPacientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nový pacient" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#B0B0B0" Padding="15">
            <TextBlock Text="Nový pacient" 
                       FontSize="28" 
                       Foreground="Black" 
                       HorizontalAlignment="Center" 
                       FontFamily="Segoe UI Light"/>
        </Border>

        <Grid Grid.Row="1" Margin="30,20,30,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Background="#C0C0C0" Padding="15,5" Margin="0,0,15,0">
                <TextBlock Text="Pacient ID" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Grid.Column="1" Text="(Generováno automaticky)" VerticalAlignment="Center" FontStyle="Italic" Foreground="Gray"/>
        </Grid>

        <Grid Grid.Row="2" Margin="30,10,30,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <Label Content="Titul před" Background="#D3D3D3" VerticalContentAlignment="Center" Padding="10,5" Margin="0,0,5,0"/>
                <TextBox Width="70" Margin="0,0,20,0" VerticalContentAlignment="Center"/>

                <Label Content="Jméno" Background="#D3D3D3" VerticalContentAlignment="Center" Padding="10,5" Margin="0,0,5,0"/>
                <TextBox Width="150" Margin="0,0,20,0" VerticalContentAlignment="Center"/>

                <Label Content="Příjmení" Background="#D3D3D3" VerticalContentAlignment="Center" Padding="10,5" Margin="0,0,5,0"/>
                <TextBox Width="150" Margin="0,0,20,0" VerticalContentAlignment="Center"/>

                <Label Content="Titul za" Background="#D3D3D3" VerticalContentAlignment="Center" Padding="10,5" Margin="0,0,5,0"/>
                <TextBox Width="70" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <Label Content="Datum Narození" Background="#D3D3D3" VerticalContentAlignment="Center" Padding="10,5" Margin="0,0,5,0"/>
                <DatePicker Width="120" Margin="0,0,20,0" VerticalContentAlignment="Center"/>

                <Label Content="Adresa" Background="#D3D3D3" VerticalContentAlignment="Center" Padding="10,5" Margin="0,0,5,0"/>
                <TextBox Width="200" Margin="0,0,20,0" VerticalContentAlignment="Center"/>

                <Label Content="Pohlaví" Background="#D3D3D3" VerticalContentAlignment="Center" Padding="10,5" Margin="0,0,5,0"/>
                <ComboBox Width="80" Margin="0,0,20,0" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="Muž"/>
                    <ComboBoxItem Content="Žena"/>
                </ComboBox>

                <Label Content="Lékař" Background="#D3D3D3" VerticalContentAlignment="Center" Padding="10,5" Margin="0,0,5,0"/>
                <ComboBox Width="120" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Orientation="Horizontal">
                <Label Content="Číslo pojištěnce" Background="#D3D3D3" VerticalContentAlignment="Center" Padding="10,5" Margin="0,0,5,0"/>
                <TextBox Width="180" Margin="0,0,20,0" VerticalContentAlignment="Center"/>

                <Label Content="Pojišťovna" Background="#D3D3D3" VerticalContentAlignment="Center" Padding="10,5" Margin="0,0,5,0"/>
                <ComboBox Width="150" VerticalContentAlignment="Center"/>
            </StackPanel>

            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Content="Poznámky" Background="#D3D3D3" VerticalContentAlignment="Top" Padding="10,5" Margin="0,0,5,0" Height="80"/>
                <TextBox Grid.Column="1" Text="Text..." VerticalContentAlignment="Top" Padding="5" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="80"/>
            </Grid>
        </Grid>

        <Border Grid.Row="3" Padding="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="💾" FontSize="30" VerticalAlignment="Center" Margin="0,0,10,0"/>

                <Button Content="Uložit" Width="120" Height="40" Background="#C0C0C0" BorderThickness="0" FontWeight="SemiBold" FontSize="16"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>