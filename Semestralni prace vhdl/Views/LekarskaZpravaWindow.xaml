<Window x:Class="Semestralni_prace_vhdl.Views.LekarskaZpravaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lékařská zpráva" Height="550" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#B0B0B0" Padding="15">
            <TextBlock Text="Lékařská zpráva" 
                       FontSize="28" 
                       Foreground="Black" 
                       HorizontalAlignment="Center" 
                       FontFamily="Segoe UI Light"/>
        </Border>

        <Grid Grid.Row="1" Margin="30,20,30,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Border Background="#C0C0C0" Padding="10,5" Margin="0,0,10,0">
                    <TextBlock Text="Pacient ID" FontWeight="SemiBold"/>
                </Border>
                <TextBox Text="123" IsReadOnly="True" Width="50" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Background="#F0F0F0"/>
            </StackPanel>

            <Label Grid.Row="2" Grid.Column="0" Content="Datum posledního vyšetření:" Background="#D3D3D3" VerticalContentAlignment="Center" Padding="10,5"/>
            <DatePicker Grid.Row="2" Grid.Column="2" HorizontalAlignment="Left" Width="150" VerticalContentAlignment="Center"/>

            <Label Grid.Row="4" Grid.Column="0" Content="Popis příznaků/obtíží:" Background="#D3D3D3" VerticalContentAlignment="Center" Padding="10,5"/>
            <TextBox Grid.Row="4" Grid.Column="2" Height="60" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="5"/>

            <Label Grid.Row="6" Grid.Column="0" Content="Diagnóza:" Background="#D3D3D3" VerticalContentAlignment="Center" Padding="10,5"/>
            <TextBox Grid.Row="6" Grid.Column="2" Height="40" TextWrapping="Wrap" Padding="5"/>

            <Label Grid.Row="8" Grid.Column="0" Content="Doporučení / další vyšetření:" Background="#D3D3D3" VerticalContentAlignment="Center" Padding="10,5"/>
            <TextBox Grid.Row="8" Grid.Column="2" Height="60" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="5"/>
        </Grid>

        <Border Grid.Row="2" Padding="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="💾" FontSize="30" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Button Content="Uložit" Width="120" Height="40" Background="#C0C0C0" BorderThickness="0" FontWeight="SemiBold" FontSize="16"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>