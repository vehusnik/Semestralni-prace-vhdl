<UserControl x:Class="Semestralni_prace_vhdl.Views.PrehledPacientuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Semestralni_prace_vhdl.ViewModels"
             xmlns:conv="clr-namespace:Semestralni_prace_vhdl.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="1000">

    <UserControl.Resources>
        <conv:EnumDescriptionConverter x:Key="EnumConverter"/>

        <Style x:Key="DetailButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:PřehledPacientuVM />
    </UserControl.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Seznam pacientů" FontSize="24" FontWeight="Bold" 
                       HorizontalAlignment="Center" Grid.ColumnSpan="2" Margin="0,0,0,20"/>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom">
                <TextBlock Text="Vyhledat pacienta:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                <TextBox Width="200" Padding="5" Text="{Binding HledanyText, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Content="🔍" Command="{Binding HledatCommand}" Margin="5,0,0,0" Padding="5"/>
            </StackPanel>
        </Grid>

        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding SeznamPacientu}" 
                  SelectedItem="{Binding VybranyPacient}"
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  BorderThickness="1"
                  BorderBrush="Gray">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>

                <DataGridTextColumn Header="Titul před" Binding="{Binding TitulPred, Converter={StaticResource EnumConverter}}" Width="70"/>

                <DataGridTextColumn Header="Jméno" Binding="{Binding Jmeno}" Width="*"/>
                <DataGridTextColumn Header="Příjmení" Binding="{Binding Prijmeni}" FontWeight="Bold" Width="*"/>

                <DataGridTextColumn Header="Titul za" Binding="{Binding TitulZa, Converter={StaticResource EnumConverter}}" Width="60"/>

                <DataGridTextColumn Header="Datum narození" Binding="{Binding DatumNarozeni, StringFormat=dd.MM.yyyy}" Width="100"/>

                <DataGridTextColumn Header="Adresa" Binding="{Binding Adresa}" Width="150"/>

                <DataGridTextColumn Header="Pohlaví" Binding="{Binding Pohlavi, Converter={StaticResource EnumConverter}}" Width="70"/>

                <DataGridTextColumn Header="Číslo pojištěnce" Binding="{Binding CisloPojistence}" Width="100"/>

                <DataGridTextColumn Header="Pojišťovna" Binding="{Binding Pojistovna, Converter={StaticResource EnumConverter}}" Width="80"/>

                <DataGridTextColumn Header="Lékař" Binding="{Binding Lekar}" Width="100"/>

                <DataGridTextColumn Header="Poznámky" Binding="{Binding Poznamka}" Width="100"/>

                <DataGridTemplateColumn Header="Detail" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="🔍" 
                                    Style="{StaticResource DetailButtonStyle}"
                                    Command="{Binding DataContext.OtevritDetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                    CommandParameter="{Binding}"
                                    ToolTip="Zobrazit kartu pacienta"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="+ PŘIDAT PACIENTA" Command="{Binding PridatCommand}" 
                    Background="LightGray" Padding="15,10" Margin="10"/>

            <Button Content="+ PŘIDAT LÉKAŘSKOU ZPRÁVU" Command="{Binding PridatZpravuCommand}" 
                    Background="LightGray" Padding="15,10" Margin="10"/>

            <Button Content="✎ UPRAVIT ÚDAJE" Command="{Binding UpravitCommand}" 
                    Background="LightGray" Padding="15,10" Margin="10"/>

            <Button Content="- ODSTRANIT" Command="{Binding SmazatCommand}" 
                    Background="#FFCDD2" Padding="15,10" Margin="10"/>
        </StackPanel>
    </Grid>
</UserControl>